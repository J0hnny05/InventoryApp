{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ExchangeRates": {
    "Endpoint": "https://open.er-api.com/v6/latest/EUR",
    "StaleAfterHours": 12
  },
  "Jwt": {
    "Issuer": "InventoryApp",
    "Audience": "InventoryApp.Client",
    "SigningKey": "",
    "LifetimeSeconds": 900,
    "RefreshLifetimeSeconds": 604800,
    "ClockSkewSeconds": 5
  },
  "Demo": {
    "EnableTokenEndpoint": true,
    "TokenLifetimeSeconds": 60
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "AllowedHosts": "*"
}
